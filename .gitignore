# Python bytecode
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# Virtual environments
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints/

# Distribution / packaging
dist/
build/
*.egg-info/
.eggs/

# Data files (adjust extensions to your needs)
*.npy
*.npz
*.h5
*.hdf5
*.pkl
*.pt
*.pth
*.mat
*.csv
*.nc

# Large output folders
outputs/
results/
logs/
checkpoints/
runs/

# Exception: paper manuscript figures live under paper/sections/figures/results/
# even though the top-level results/ folder is ignored.
!paper/sections/figures/results/
!paper/sections/figures/results/*

# IDE
.vscode/
.idea/
*.swp

# Claude Code local state (settings overrides, schedule locks)
.claude/

# OS
.DS_Store
Thumbs.db

# Environment variables / secrets
.env
*.key

# LaTeX build artifacts (auto-regenerable; source is paper/sections/*.md + main.tex)
paper/main.aux
paper/main.bbl
paper/main.blg
paper/main.log
paper/main.out
paper/main.toc
paper/main.fdb_latexmk
paper/main.fls
paper/.compile_cache/
paper/sections/figures/tikz/*.aux
paper/sections/figures/tikz/*.log
paper/sections/figures/tikz/*-1.png
paper/sections/figures/tikz/*preview-1.png

# Generated section .tex files (produced from .md by scripts/_oneoff_md_to_tex.py)
# paper/sections/abstract.tex (now canonical, hand-authored)
# paper/sections/section_*.tex (now canonical, hand-authored)
